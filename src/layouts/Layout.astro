---
const {
  title,
  description,
  image,
  type,
  pubDate,
  modDate,
  author = 'Fran Moreno',
  tags
} = Astro.props

const defaultImage = '/franmoreno.jpg'

const socialImage = image
  ? new URL(image, Astro.site)
  : new URL(defaultImage, Astro.site)
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const siteOrigin = new URL('/', Astro.site).toString().replace(/\/$/, '')

const isArticle = type === 'blog'

const personSchema = {
  '@type': 'Person',
  '@id': `${siteOrigin}/#person`,
  name: 'Fran Moreno',
  alternateName: 'siner',
  url: `${siteOrigin}/`,
  image: `${siteOrigin}/franmoreno.jpg`,
  jobTitle: 'Desarrollador Web Frontend',
  description:
    'Ingeniero informático con más de 15 años de experiencia desarrollando aplicaciones web con React, Next.js y Astro.',
  email: 'mailto:fran@franmoreno.com',
  knowsAbout: [
    'React',
    'Next.js',
    'Astro',
    'TypeScript',
    'JavaScript',
    'Tailwind CSS',
    'Cloudflare',
    'Desarrollo Web Frontend'
  ],
  sameAs: [
    'https://twitter.com/siner',
    'https://github.com/siner',
    'https://www.linkedin.com/in/franmorenonavas/',
    'https://bsky.app/profile/franmoreno.com',
    'https://instagram.com/fransiner'
  ]
}

const websiteSchema = {
  '@type': 'WebSite',
  '@id': `${siteOrigin}/#website`,
  url: `${siteOrigin}/`,
  name: 'Fran Moreno',
  description: 'Web personal y blog de Fran Moreno, desarrollador web frontend.',
  inLanguage: 'es-ES',
  publisher: { '@id': `${siteOrigin}/#person` },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteOrigin}/blog?q={search_term_string}`
    },
    'query-input': 'required name=search_term_string'
  }
}

const articleSchema = isArticle
  ? {
      '@type': 'BlogPosting',
      '@id': `${canonicalURL}#article`,
      headline: title,
      description,
      image: socialImage.toString(),
      datePublished: pubDate
        ? new Date(pubDate).toISOString()
        : undefined,
      dateModified: modDate
        ? new Date(modDate).toISOString()
        : pubDate
          ? new Date(pubDate).toISOString()
          : undefined,
      author: { '@id': `${siteOrigin}/#person` },
      publisher: { '@id': `${siteOrigin}/#person` },
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
      inLanguage: 'es-ES',
      keywords: tags && tags.length ? tags.join(', ') : undefined
    }
  : null

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [personSchema, websiteSchema, ...(articleSchema ? [articleSchema] : [])]
}

const siteName = 'Fran Moreno'
const fullTitle = isArticle ? `${title} | ${siteName}` : title

import Header from '../components/header.astro'
import Footer from '../components/footer.astro'
import { ClientRouter } from 'astro:transitions'

import '../styles/globals.css'
---

<!doctype html>
<html lang="es" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://umami.franmoreno.com" />
    <link rel="dns-prefetch" href="https://umami.franmoreno.com" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="theme-color" content="#4f46e5" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link
      rel="alternate"
      type="application/rss+xml"
      title="Fran Moreno Blog"
      href={new URL('/rss.xml', Astro.site)}
    />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Fran Moreno" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:locale" content="es_ES" />

    {
      isArticle && pubDate && (
        <meta
          property="article:published_time"
          content={new Date(pubDate).toISOString()}
        />
      )
    }
    {
      isArticle && (modDate || pubDate) && (
        <meta
          property="article:modified_time"
          content={new Date(modDate || pubDate).toISOString()}
        />
      )
    }
    {isArticle && <meta property="article:author" content={author} />}
    {
      isArticle &&
        tags &&
        tags.map((tag: string) => (
          <meta property="article:tag" content={tag} />
        ))
    }

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@siner" />
    <meta name="twitter:creator" content="@siner" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={title} />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />

    <script
      async
      src="https://umami.franmoreno.com/script.js"
      data-website-id="c3fe7795-f77a-4e15-a054-32e7394ecce3"></script>
    <ClientRouter />
  </head>
  <body
    class="min-h-screen bg-gradient-to-b from-white to-gray-50 dark:from-[#333333] dark:to-[#222222] dark:text-[#f5f5f5] transition-colors duration-300"
  >
    <div class="relative">
      <div
        class="absolute inset-0 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] dark:bg-[radial-gradient(#444444_1px,transparent_1px)] [background-size:16px_16px] -z-10 opacity-50"
      >
      </div>
      <Header />
      <main
        class="container mx-auto p-4 min-h-[calc(100vh-200px)]"
        transition:animate="fade"
      >
        <slot />
      </main>
      <Footer />
    </div>
    <script is:inline>
      try {
        const theme =
          localStorage.getItem('theme') ||
          (matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light')
        document.documentElement.classList.toggle('dark', theme === 'dark')
        localStorage.setItem('theme', theme)
      } catch (e) {}
    </script>
  </body>
</html>
